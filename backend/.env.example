# ── OpenAI (ArshnivLabs gateway) ─────────────────────────────────────────────
OPENAI_API_KEY=learner020
OPENAI_BASE_URL=https://keygateway.arshnivlabs.com/v1
LLM_MODEL=gpt-4o-mini
EMBEDDING_MODEL=text-embedding-3-small

# ── LangSmith (get your key from smith.langchain.com) ────────────────────────
LANGCHAIN_API_KEY=ls__your_key_here
LANGCHAIN_TRACING_V2=true
LANGCHAIN_PROJECT=supply-chain-risk-intel

# ── MySQL (matches docker-compose.yml defaults) ───────────────────────────────
MYSQL_URL=mysql+aiomysql://scm_user:scm_pass@localhost:3306/supply_chain_db
MYSQL_URL_SYNC=mysql+pymysql://scm_user:scm_pass@localhost:3306/supply_chain_db

# ── ChromaDB ──────────────────────────────────────────────────────────────────
CHROMA_PERSIST_DIR=./chroma_db
CHROMA_COLLECTION_NAME=supply_chain_incidents

# ── JWT (generate with: python -c "import secrets; print(secrets.token_hex(32))") ──
JWT_SECRET_KEY=change-this-to-a-random-32-char-string
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# ── CORS ──────────────────────────────────────────────────────────────────────
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# ── Redis (optional — used for caching/job queue) ─────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ── App ───────────────────────────────────────────────────────────────────────
APP_ENV=development
LOG_LEVEL=INFO
